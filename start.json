{
  "run": [
    {
      "method": "shell.run",
      "params": {
        "path": "infernosaber",
        "message": [
          "{{os.platform() === 'win32' ? 'conda activate inferno_env && python main_app.py' : 'source activate inferno_env && python main_app.py'}}"
        ],
        "on": [
          {
            "event": "/(http:\\/\\/[a-zA-Z0-9.]+:[0-9]+)/i",
            "done": true
          },
          {
            "event": "/errno/i",
            "break": false
          },
          {
            "event": "/error:/i",
            "break": false
          }
        ]
      }
    },
    {
      "method": "local.set",
      "params": {
        "url": "{{input.event[1]}}"
      }
    },
    {
      "method": "self.set",
      "params": {
        "session.json": {
          "url": "{{local.url}}"
        }
      }
    },
    {
      "method": "browser.open",
      "params": {
        "uri": "{{local.url}}",
        "target": "_blank"
      }
    },
    {
      "method": "process.wait"
    }
  ]
}
