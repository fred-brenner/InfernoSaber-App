{
  "daemon": true,
  "run": [
    {
      "method": "shell.run",
      "params": {
        "path": "infernosaber",
        "conda": "conda_env",
        "message": "python main_app.py",
        "on": [
          {
            "event": "/(http:\\/\\/[0-9.:]+)/",
            "done": true
          }
        ]
      }
    },
    {
      "method": "local.set",
      "params": {
        "url": "{{input.event[1]}}"
      }
    }
  ]
}
