{
  "run": [
    {
      "when": "{{!exists('infernosaber')}}",
      "method": "shell.run",
      "params": {
        "message": "git clone -b main_app https://github.com/fred-brenner/InfernoSaber---BeatSaber-Automapper.git infernosaber"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "path": "infernosaber",
        "conda": {
          "path": "conda_env",
          "python": "python=3.10"
        },
        "message": [
          "conda install -c conda-forge -y ffmpeg",
          "{{platform === 'darwin' ? 'uv pip install --python \"$(which python)\" aubio pydub' : 'conda install -c conda-forge -y aubio pydub'}}",
          "uv pip install --python \"$(which python)\" --isolated -r requirements.txt"
        ]
      }
    },
    {
      "method": "input",
      "params": {
        "title": "Install Success",
        "description": "Go back to the dashboard and launch the app"
      }
    },
    {
      "method": "web.open",
      "params": {
        "uri": "/?selected=infernosaber"
      }
    }
  ]
}
