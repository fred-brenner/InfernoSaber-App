{
  "run": [
    {
      "method": "shell.run",
      "params": {
        "message": "git clone -b main_app https://github.com/fred-brenner/InfernoSaber---BeatSaber-Automapper.git infernosaber"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "conda create -n inferno_env -y python=3.10"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "path": "infernosaber",
        "message": "conda install -n inferno_env -c conda-forge -y ffmpeg=4.3.1 aubio pydub"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "path": "infernosaber",
        "message": "conda run -n inferno_env pip install --isolated -r requirements.txt"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "echo. > install_successfull.txt"
      }
    },
    {
      "method": "input",
      "params": {
        "title": "Install Success",
        "description": "Go back to the dashboard and launch the app"
      }
    },
    {
      "method": "browser.open",
      "params": {
        "uri": "/?selected=infernosaber"
      }
    }
  ]
}
