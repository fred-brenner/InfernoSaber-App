{
  "run": [
    {
      "method": "shell.run",
      "params": {
        "path": "infernosaber",
        "conda": "conda_env",
        "message": [
          "git fetch origin main_app",
          "git pull --ff-only origin main_app",
          "conda install -c conda-forge -y ffmpeg",
          "{{platform === 'darwin' ? 'uv pip install --python \"$(which python)\" aubio pydub' : 'conda install -c conda-forge -y aubio pydub'}}",
          "uv pip install --python \"$(which python)\" --isolated -r requirements.txt"
        ]
      }
    },
    {
      "method": "input",
      "params": {
        "title": "Update Success",
        "description": "The app has been updated successfully!"
      }
    },
    {
      "method": "web.open",
      "params": {
        "uri": "/?selected=infernosaber"
      }
    }
  ]
}
