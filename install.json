{
  "run": [
    {
      "when": "{{!exists('infernosaber')}}",
      "method": "shell.run",
      "params": {
        "message": "git clone -b main_app https://github.com/fred-brenner/InfernoSaber---BeatSaber-Automapper.git infernosaber"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "path": "infernosaber",
        "conda": {
          "path": "conda_env",
          "python": "python=3.10"
        },
        "message": [
          "conda install -c conda-forge -y aubio pydub",
          "conda install -y conda-forge::ffmpeg=*=*gpl*",
          "uv pip install --isolated -r requirements.txt"
        ]
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'type nul > install_successfull.txt' : 'touch install_successfull.txt'}}"
      }
    },
    {
      "method": "input",
      "params": {
        "title": "Install Success",
        "description": "Go back to the dashboard and launch the app"
      }
    },
    {
      "method": "web.open",
      "params": {
        "uri": "/?selected=infernosaber"
      }
    }
  ]
}
